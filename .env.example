# Copy to .env and fill in. NEVER commit .env.
# YouTube Data API v3 key (Google Cloud Console -> APIs -> Credentials -> API key).
# Needed to READ comments. Free quota is far more than enough for 1 run/day.
YT_API_KEY=

# Optional: path to OAuth client secret JSON for auto-upload (see docs/SETUP-YOUTUBE.md)
YT_CLIENT_SECRET_FILE=pipeline/.state/client_secret.json
